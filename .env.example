# Copy this file to `.env` (it is gitignored) and edit as needed.
#
# Then start the gateway with:
#   ./scripts/serve.sh

# Minimal config: use a preset to avoid tuning lots of env vars.
# CODEX_PRESET=codex-fast
#
# OpenClaw + Cursor (Linux server or Mac): match `scripts/litellm-bridge/start-bridge.sh` — Composer 2 Fast
# for all Cursor-backed requests, with optional codex/gemini prefixes on the same gateway:
#   CODEX_PRESET=multi-composer2
#   CURSOR_AGENT_BIN=/full/path/to/cursor-agent   # if not on PATH (common under systemd)
#   CURSOR_AGENT_WORKSPACE=/home/you/.cursor-agent-workspace

# Optional auth (if set, clients must send: Authorization: Bearer <token>)
CODEX_GATEWAY_TOKEN=devtoken

# LiteLLM proxy (when using scripts/litellm-bridge): same value for master key + client Bearer.
# LITELLM_MASTER_KEY=
# For Claude Code against the bridge, also set (or export when sourcing `.env`):
# ANTHROPIC_AUTH_TOKEN=<same as LITELLM_MASTER_KEY>
#
# Vision routing (scripts/litellm-bridge/vision_route_hook.py): Composer 2 Fast for text,
# Cursor `auto` when messages include images. Defaults are fine unless you need to disable or retarget.
# LITELLM_VISION_ROUTE=1
# LITELLM_VISION_TARGET_MODEL=cursor-vision-auto
# LITELLM_VISION_SOURCE_MODELS=cursor-composer-2-fast,composer-2-fast,claude-haiku-4-5-20251001

# Optional overrides (usually don't need these if using a preset)
# CODEX_WORKSPACE=/path/to/workspace
# If unset, the gateway uses an empty temp dir under /tmp by default.
# CURSOR_AGENT_WORKSPACE=~/.openclaw
# Cursor preset `cursor-auto` defaults to ~/.openclaw for OpenClaw integration.
# `~` is expanded to an absolute path by the gateway.
# CODEX_LOG_MODE=qa
CODEX_LOG_EVENTS=1
# CODEX_LOG_REQUEST_CURL=1
# CODEX_CLI_HOME=/absolute/path/to/.codex-gateway-home
CODEX_CODEX_ALLOW_TOOLS=1
#
# For advanced tuning and multi-provider env vars, see README.md.
